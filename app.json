{
  "expo": {
    "name": "Méthode KMDC",
    "slug": "methode-kmdc",
    "version": "1.0.0",
    "scheme": "kmdc",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4F6FA"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "be.iagency.kmdc"
    },
    "android": {
      "package": "be.iagency.kmdc",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F4F6FA"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#4A6B9A"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "47ac362e-0970-422a-b8e2-e8eb071400ac"
      }
    }
  }
}
